# Force LF for all source files. Terraform reads heredoc content from .tf
# files verbatim and embeds it into ECS task definitions / EC2 user-data /
# Splunk config files. Mixing CRLF (Windows checkouts) and LF (Linux CI
# checkouts) produces byte-different rendered configs and forces unnecessary
# resource updates on every cross-platform apply.
* text=auto eol=lf

*.tf       text eol=lf
*.tfvars   text eol=lf
*.hcl      text eol=lf
*.json     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.sh       text eol=lf
*.py       text eol=lf
*.md       text eol=lf
*.conf     text eol=lf
*.spl      text eol=lf

*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.zip      binary
*.gz       binary
*.tgz      binary
